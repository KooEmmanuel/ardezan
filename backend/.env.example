# Ardezan backend — local development DEFAULTS / TEMPLATE.
#
# DO NOT PUT REAL SECRETS IN THIS FILE.
# This .env.example is committed to version control as a template for new
# contributors. Copy it to .env (which is gitignored) and put real values there.

APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=console            # json | console

# ── Database ───────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
MONGO_DB=atelier_dev

# ── Queue (Redis-backed arq) ───────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS ───────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Only trust X-Forwarded-For / X-Real-IP for the client IP when a reverse
# proxy / load balancer that OVERWRITES these headers sits in front of the
# app. Leave false when the app is reachable directly, otherwise clients can
# spoof their IP to bypass IP-scoped rate limits. Set true in production
# behind a trusted proxy (nginx, Cloudflare, ALB, etc.).
TRUST_FORWARDED_FOR=false

# ── Sessions / signed tokens ───────────────────────────────────
# Generate THREE INDEPENDENT values with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET_CUSTOMER=change-me-customer-secret
SESSION_SECRET_ADMIN=change-me-admin-secret
GUEST_TOKEN_SECRET=change-me-guest-token-secret

# First-admin bootstrap. If both are set on first boot and no admin exists
# yet, an "owner" admin is created. Idempotent on subsequent restarts.
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_NAME=Owner

# ── AI provider (google-genai → Gemini) ────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL_ANALYZER=gemini-2.5-flash
GEMINI_MODEL_RECOMMENDER=gemini-2.5-flash
GEMINI_MODEL_DESIGNER=gemini-2.5-flash-image
GEMINI_MODEL_SAFETY=gemini-2.5-flash

# ── AI quotas + spend controls (defaults; runtime overrides via settings collection) ──
AI_KILL_SWITCH=false
AI_DAILY_SPEND_CEILING_USD=75
AI_ANONYMOUS_DAILY_LIMIT=3
AI_REGISTERED_WEEKLY_LIMIT=10

# ── AI safety classifier (M6.2) ────────────────────────────────
# Master switch — keep True in production. Disable only as a break-glass.
AI_SAFETY_CLASSIFIER_ENABLED=true
# Fail-open lets uploads through if Gemini errors. Convenient for local
# dev without an API key — MUST stay False in production.
AI_SAFETY_FAIL_OPEN=true

# ── Rate limits (M6.3, REQ-062) ────────────────────────────────
# Per-IP burst window on POST /try-on/sessions (60s window).
RATE_LIMIT_UPLOAD_IP_PER_MIN=6
# Per-identity sustain window (1h) — keyed off anonymous_session_id /
# customer cookie, so shared-NAT users don't get penalized by one bad IP.
RATE_LIMIT_UPLOAD_FINGERPRINT_PER_HOUR=20
# Login brute-force / credential-stuffing limits (admin + customer login).
# Per-IP burst (60s window) + per-email targeted window (15min).
RATE_LIMIT_LOGIN_IP_PER_MIN=10
RATE_LIMIT_LOGIN_EMAIL_PER_15MIN=7

# ── Inventory ──────────────────────────────────────────────────
CHECKOUT_SOFT_HOLD_MINUTES=10

# Daily low-stock digest emailed to the operator. The cron lives in the
# arq worker (worker/jobs/inventory_alerts.py) and runs at 09:00 daily.
# If LOW_STOCK_ALERT_EMAIL is empty the worker silently skips the send
# — keeps dev environments from spamming MailHog.
LOW_STOCK_ALERT_ENABLED=true
LOW_STOCK_ALERT_EMAIL=

# ── Payments (OD-003 placeholder — Stripe is the default) ──────
# Use Stripe TEST keys for local dev (sk_test_…/pk_test_…) and LIVE only in prod.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# The webhook SIGNING SECRET — MUST start with "whsec_". Get it from the
# Stripe Dashboard (Developers → Webhooks → your endpoint) or, for local dev,
# from the `stripe listen` output. NOT your account id (acct_…) or API key.
STRIPE_WEBHOOK_SECRET=

# ── Object storage ────────────────────────────────────────────────
# Pick a backend. ``local`` writes files to <repo>/storage and serves them
# via the API itself (no per-file egress cost — good for dev). ``b2`` uses
# Backblaze B2 native API for production.
STORAGE_BACKEND=local

# Where local files go (when STORAGE_BACKEND=local). Relative paths resolve
# against the repo root (one level up from backend/).
STORAGE_LOCAL_DIR=storage

# Public URL the storefront uses to fetch local files. In dev it's the API
# server; in prod swap to your domain.
STORAGE_LOCAL_PUBLIC_BASE_URL=http://localhost:8000

# B2 credentials (used when STORAGE_BACKEND=b2). Get from B2 → App Keys.
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=

# All storage keys are prefixed with this so multiple projects can share one
# bucket or directory without collisions. Keep the trailing slash.
STORAGE_KEY_PREFIX=atelier/

# ── Email (SMTP) ───────────────────────────────────────────────
# Local dev: MailHog container (docker compose up brings it up).
#   Web UI at http://localhost:8025 to view captured emails.
# Production: swap to your provider — Resend, Mailgun, SES, Postmark.
#   typical: SMTP_PORT=587, SMTP_TLS_MODE=starttls
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS_MODE=none            # none | starttls | ssl
SMTP_FROM_NAME=Ardezan
SMTP_FROM_EMAIL=orders@ardezan.local
EMAIL_LINK_BASE_URL=http://localhost:3000

# ── Launch market (OD-011 placeholder) ─────────────────────────
STORE_COUNTRY=US
STORE_CURRENCY=USD
STORE_LOCALE=en-US

# ── Retention (REQ-066, REQ-068) ───────────────────────────────
ANONYMOUS_UPLOAD_RETENTION_MINUTES=15
ANONYMOUS_GENERATED_RETENTION_HOURS=24

# ── Agents (Google ADK + MongoDB MCP) ──────────────────────────
# The Stylist agent (app/agents/stylist_agent.py) wraps our existing
# recommender in Google's Agent Development Kit. The MCP toolset lets
# it talk to MongoDB through the official mongodb-mcp-server.
#
# false → catalog queries hit Mongo directly via Motor (default).
# true  → spawn `npx mongodb-mcp-server --connectionString $MONGO_URL`
#         and route catalog queries through MCP tools.
#
# The MCP server always reuses MONGO_URL above so there is exactly one
# database connection string to maintain (local in dev, Atlas in prod).
MCP_ENABLED=false

# ADK reads GOOGLE_API_KEY. Bridge from GEMINI_API_KEY if you prefer
# keeping a single key in your env.
GOOGLE_API_KEY=
