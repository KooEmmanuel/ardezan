# Ardezan frontend — environment template.
#
# Copy this file to .env.local (which is gitignored) and fill in values
# for your environment. ``NEXT_PUBLIC_`` is the Next.js prefix that
# exposes a variable to the browser — anything without it stays
# server-only.

# Backend API origin. The browser hits this directly (cart, try-on,
# checkout) and SSR pages also use it for server-side fetches.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Public origin of the storefront — used for canonical URLs, sitemap,
# robots, and Open Graph tags. Set per environment.
#   Local dev:    http://localhost:3000
#   Vercel prod:  https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Tells next/image whether the storage backend is on a CDN-friendly host.
# - ``local`` (default): image optimization is OFF because images come
#   from the API at http://localhost:8000/api/v1/storage/* which the
#   Next image optimizer would refuse as a private/loopback IP.
# - ``b2``: image optimization is ON; the optimizer transcodes images
#   served from f005.backblazeb2.com to AVIF/WebP.
NEXT_PUBLIC_STORAGE_BACKEND=local
