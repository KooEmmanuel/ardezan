{
  "name": "ardezan-hero-video",
  "version": "1.0.0",
  "private": true,
  "description": "Remotion project for the Ardezan homepage hero cinematic (Act 1 Veo studio footage + Act 2 coded try-on flow).",
  "scripts": {
    "dev": "remotion studio",
    "render": "remotion render HeroVideo out/hero.mp4 --codec=h264",
    "render:webm": "remotion render HeroVideo out/hero.webm --codec=vp8",
    "render:act2": "remotion render Act2Flow out/act2.mp4 --codec=h264",
    "still": "remotion still HeroVideo out/poster.png --frame=120",
    "upgrade": "remotion upgrade"
  },
  "dependencies": {
    "@remotion/cli": "4.0.290",
    "@remotion/google-fonts": "4.0.290",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.290"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "typescript": "5.6.3"
  }
}
